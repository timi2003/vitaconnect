generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                    String              @id @default(cuid())
  email                 String              @unique
  emailVerified         DateTime?
  name                  String?
  image                 String?
  passwordHash          String?
  role                  UserRole            @default(PATIENT)
  phone                 String?
  dateOfBirth           DateTime?
  gender                Gender?
  bloodType             BloodType?
  height                Float?
  weight                Float?
  allergies             String[]
  chronicConditions     String[]
  emergencyContact      Json?
  address               Json?
  timezone              String              @default("UTC")
  locale                String              @default("en")
  isActive              Boolean             @default(true)
  isVerified            Boolean             @default(false)
  notifPrefs            Json?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  accounts              Account[]
  appointmentsAsDoctor  Appointment[]       @relation("DoctorAppointments")
  appointmentsAsPatient Appointment[]       @relation("PatientAppointments")
  auditLogs             AuditLog[]
  deviceConnections     DeviceConnection[]
  doctorProfile         DoctorProfile?
  healthConnectSync     HealthConnectSync[]
  healthMetrics         HealthMetric[]
  healthRecords         HealthRecord[]
  labResults            LabResult[]
  documents             MedicalDocument[]
  messages              Message[]
  notifications         Notification[]
  patientProfile        PatientProfile?
  payments              Payment[]
  prescriptions         Prescription[]
  reviews               Review[]
  sessions              Session[]
  videoSessions         VideoSession[]
}

model PatientProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  insuranceProvider     String?
  insurancePolicyNo     String?
  insuranceGroupNo      String?
  primaryDoctorId       String?
  medicalHistorySummary String?
  preferredLanguage     String   @default("en")
  consentForms          Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DoctorProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  licenseNumber      String             @unique
  licenseExpiry      DateTime?
  npiNumber          String?            @unique
  specializations    String[]
  subSpecializations String[]
  qualifications     Json[]
  experience         Int                @default(0)
  bio                String?
  consultationFee    Float              @default(0)
  followUpFee        Float              @default(0)
  currency           String             @default("USD")
  availableFor       ConsultType[]
  languages          String[]
  rating             Float              @default(0)
  totalReviews       Int                @default(0)
  totalConsultations Int                @default(0)
  isAvailableNow     Boolean            @default(false)
  hospital           String?
  department         String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  availabilitySlots  AvailabilitySlot[]
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews            Review[]
}

model AvailabilitySlot {
  id           String        @id @default(cuid())
  doctorId     String
  dayOfWeek    Int
  startTime    String
  endTime      String
  slotDuration Int           @default(30)
  isRecurring  Boolean       @default(true)
  specificDate DateTime?
  isAvailable  Boolean       @default(true)
  createdAt    DateTime      @default(now())
  doctor       DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  doctorId        String
  scheduledAt     DateTime
  duration        Int               @default(30)
  type            ConsultType       @default(VIDEO)
  status          AppointmentStatus @default(SCHEDULED)
  reason          String?
  symptoms        String[]
  notes           String?
  doctorNotes     String?
  diagnosis       String?
  followUpDate    DateTime?
  roomId          String?
  recordingUrl    String?
  cancelReason    String?
  cancelledBy     String?
  rescheduledFrom String?
  reminderSent    Boolean           @default(false)
  paymentId       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  doctor          User              @relation("DoctorAppointments", fields: [doctorId], references: [id])
  patient         User              @relation("PatientAppointments", fields: [patientId], references: [id])
  payment         Payment?          @relation(fields: [paymentId], references: [id])
  labOrders       LabOrder[]
  messages        Message[]
  prescriptions   Prescription[]
  review          Review?
  videoSession    VideoSession?
}

model VideoSession {
  id            String        @id @default(cuid())
  appointmentId String        @unique
  userId        String
  roomId        String        @unique
  provider      String        @default("jitsi")
  startedAt     DateTime?
  endedAt       DateTime?
  duration      Int?
  recordingUrl  String?
  transcriptUrl String?
  status        SessionStatus @default(PENDING)
  participants  Json?
  createdAt     DateTime      @default(now())
  appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id])
}

model HealthRecord {
  id           String    @id @default(cuid())
  userId       String
  type         String
  title        String
  description  String?
  diagnosis    String?
  icdCode      String?
  severity     Severity?
  onsetDate    DateTime?
  resolvedDate DateTime?
  isActive     Boolean   @default(true)
  attachments  String[]
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HealthMetric {
  id         String           @id @default(cuid())
  userId     String
  type       HealthMetricType
  value      Float
  value2     Float?
  unit       String
  recordedAt DateTime
  source     MetricSource     @default(MANUAL)
  deviceId   String?
  syncId     String?
  notes      String?
  isAbnormal Boolean          @default(false)
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, recordedAt])
}

model HealthConnectSync {
  id              String     @id @default(cuid())
  userId          String
  dataType        String
  lastSyncAt      DateTime?
  syncToken       String?
  status          SyncStatus @default(PENDING)
  recordsImported Int        @default(0)
  errorMessage    String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dataType])
}

model DeviceConnection {
  id           String    @id @default(cuid())
  userId       String
  deviceName   String
  deviceType   String
  manufacturer String?
  model        String?
  platform     String?
  isConnected  Boolean   @default(true)
  lastSeenAt   DateTime?
  metadata     Json?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Prescription {
  id               String             @id @default(cuid())
  patientId        String
  doctorId         String?
  appointmentId    String?
  status           PrescriptionStatus @default(ACTIVE)
  diagnosis        String?
  notes            String?
  issueDate        DateTime           @default(now())
  expiryDate       DateTime?
  refillsAllowed   Int                @default(0)
  refillsUsed      Int                @default(0)
  pharmacyNotes    String?
  digitalSignature String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  appointment      Appointment?       @relation(fields: [appointmentId], references: [id])
  patient          User               @relation(fields: [patientId], references: [id])
  medications      PrescriptionItem[]
}

model PrescriptionItem {
  id             String       @id @default(cuid())
  prescriptionId String
  medicationName String
  genericName    String?
  dosage         String
  form           String?
  strength       String?
  frequency      String
  route          String?
  duration       String
  quantity       Int
  refillQuantity Int          @default(0)
  instructions   String?
  sideEffects    String?
  interactions   String?
  isChronic      Boolean      @default(false)
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime     @default(now())
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
}

model LabOrder {
  id            String         @id @default(cuid())
  patientId     String
  doctorId      String?
  appointmentId String?
  orderDate     DateTime       @default(now())
  status        LabOrderStatus @default(PENDING)
  priority      Priority       @default(ROUTINE)
  notes         String?
  labName       String?
  dueDate       DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  appointment   Appointment?   @relation(fields: [appointmentId], references: [id])
  tests         LabOrderItem[]
  results       LabResult[]
}

model LabOrderItem {
  id         String   @id @default(cuid())
  labOrderId String
  testCode   String
  testName   String
  category   String?
  isStat     Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  labOrder   LabOrder @relation(fields: [labOrderId], references: [id], onDelete: Cascade)
}

model LabResult {
  id             String    @id @default(cuid())
  userId         String
  labOrderId     String?
  testName       String
  testCode       String?
  value          String
  unit           String?
  referenceRange String?
  isAbnormal     Boolean   @default(false)
  abnormalFlag   String?
  interpretation String?
  collectedAt    DateTime?
  reportedAt     DateTime?
  labName        String?
  labTech        String?
  reviewedBy     String?
  reviewedAt     DateTime?
  attachmentUrl  String?
  createdAt      DateTime  @default(now())
  labOrder       LabOrder? @relation(fields: [labOrderId], references: [id])
  user           User      @relation(fields: [userId], references: [id])
}

model Conversation {
  id           String                    @id @default(cuid())
  type         ConvType                  @default(DIRECT)
  title        String?
  isActive     Boolean                   @default(true)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?
  isAdmin        Boolean      @default(false)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String        @id @default(cuid())
  conversationId String?
  appointmentId  String?
  senderId       String
  content        String
  type           MessageType   @default(TEXT)
  attachments    Json?
  isRead         Boolean       @default(false)
  readAt         DateTime?
  isDeleted      Boolean       @default(false)
  editedAt       DateTime?
  replyToId      String?
  createdAt      DateTime      @default(now())
  appointment    Appointment?  @relation(fields: [appointmentId], references: [id])
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  sender         User          @relation(fields: [senderId], references: [id])
}

model Payment {
  id              String         @id @default(cuid())
  userId          String
  amount          Float
  currency        String         @default("USD")
  status          PaymentStatus  @default(PENDING)
  method          PaymentMethod?
  stripePaymentId String?        @unique
  stripeSessionId String?
  description     String?
  metadata        Json?
  refundedAmount  Float?
  refundReason    String?
  paidAt          DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  appointments    Appointment[]
  user            User           @relation(fields: [userId], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  channel   String[]         @default(["in_app"])
  sentAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id            String        @id @default(cuid())
  patientId     String
  doctorId      String
  appointmentId String        @unique
  rating        Int
  comment       String?
  tags          String[]
  isAnonymous   Boolean       @default(false)
  isVerified    Boolean       @default(true)
  response      String?
  respondedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  appointment   Appointment   @relation(fields: [appointmentId], references: [id])
  doctor        DoctorProfile @relation(fields: [doctorId], references: [id])
  patient       User          @relation(fields: [patientId], references: [id])
}

model MedicalDocument {
  id           String    @id @default(cuid())
  userId       String
  title        String
  type         DocType
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  description  String?
  tags         String[]
  isShared     Boolean   @default(false)
  sharedWith   String[]
  uploadedById String?
  date         DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, timestamp])
  @@index([resource, resourceId])
}

enum UserRole {
  PATIENT
  DOCTOR
  ADMIN
  NURSE
  PHARMACIST
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum BloodType {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
  UNKNOWN
}

enum ConsultType {
  VIDEO
  AUDIO
  CHAT
  IN_PERSON
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
  WAITING
}

enum SessionStatus {
  PENDING
  ACTIVE
  ENDED
  FAILED
}

enum Severity {
  MILD
  MODERATE
  SEVERE
  CRITICAL
}

enum HealthMetricType {
  HEART_RATE
  BLOOD_PRESSURE_SYSTOLIC
  BLOOD_PRESSURE
  BODY_TEMPERATURE
  RESPIRATORY_RATE
  OXYGEN_SATURATION
  BLOOD_GLUCOSE
  WEIGHT
  HEIGHT
  BMI
  BODY_FAT
  STEPS
  DISTANCE
  CALORIES_BURNED
  ACTIVE_MINUTES
  EXERCISE_SESSION
  SLEEP_DURATION
  SLEEP_STAGES
  CALORIES_INTAKE
  WATER_INTAKE
  MENSTRUAL_CYCLE
  STRESS_LEVEL
  MOOD
  PAIN_LEVEL
  HYDRATION
  CERVICAL_MUCUS
  OVULATION_TEST
  BASAL_BODY_TEMP
}

enum MetricSource {
  MANUAL
  HEALTH_CONNECT
  WEARABLE
  MEDICAL_DEVICE
  IMPORTED
}

enum SyncStatus {
  PENDING
  SYNCING
  SUCCESS
  FAILED
  PARTIAL
}

enum PrescriptionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
  ON_HOLD
}

enum LabOrderStatus {
  PENDING
  COLLECTED
  PROCESSING
  COMPLETED
  CANCELLED
  PARTIAL
}

enum Priority {
  ROUTINE
  URGENT
  STAT
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  AUDIO
  SYSTEM
  PRESCRIPTION
  LAB_ORDER
}

enum ConvType {
  DIRECT
  GROUP
  SUPPORT
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CARD
  BANK_TRANSFER
  INSURANCE
  WALLET
  CRYPTO
}

enum NotificationType {
  APPOINTMENT_REMINDER
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  APPOINTMENT_STARTED
  NEW_MESSAGE
  PRESCRIPTION_READY
  LAB_RESULT_READY
  HEALTH_ALERT
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  DOCTOR_AVAILABLE
  SYSTEM
}

enum DocType {
  PRESCRIPTION
  LAB_REPORT
  IMAGING
  DISCHARGE_SUMMARY
  REFERRAL
  VACCINATION
  INSURANCE
  CONSENT
  OTHER
}
