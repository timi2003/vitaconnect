// prisma/schema.prisma
// VitaConnect Telehealth Platform — Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  emailVerified     DateTime?
  name              String?
  image             String?
  passwordHash      String?
  role              UserRole   @default(PATIENT)
  phone             String?
  dateOfBirth       DateTime?
  gender            Gender?
  bloodType         BloodType?
  height            Float? // cm
  weight            Float? // kg
  allergies         String[]
  chronicConditions String[]
  emergencyContact  Json? // { name, phone, relationship }
  address           Json? // { street, city, state, country, zip }
  timezone          String     @default("UTC")
  locale            String     @default("en")
  isActive          Boolean    @default(true)
  isVerified        Boolean    @default(false)
  notifPrefs        Json? // notification preferences
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  accounts              Account[]
  sessions              Session[]
  patientProfile        PatientProfile?
  doctorProfile         DoctorProfile?
  appointmentsAsPatient Appointment[]       @relation("PatientAppointments")
  appointmentsAsDoctor  Appointment[]       @relation("DoctorAppointments")
  healthRecords         HealthRecord[]
  healthMetrics         HealthMetric[]
  prescriptions         Prescription[]
  labResults            LabResult[]
  notifications         Notification[]
  payments              Payment[]
  reviews               Review[]
  messages              Message[]
  videoSessions         VideoSession[]
  documents             MedicalDocument[]
  deviceConnections     DeviceConnection[]
  healthConnectSync     HealthConnectSync[]
  auditLogs             AuditLog[]
}

enum UserRole {
  PATIENT
  DOCTOR
  ADMIN
  NURSE
  PHARMACIST
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum BloodType {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
  UNKNOWN
}

// ─────────────────────────────────────────────
// PROFILES
// ─────────────────────────────────────────────
model PatientProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  insuranceProvider     String?
  insurancePolicyNo     String?
  insuranceGroupNo      String?
  primaryDoctorId       String?
  medicalHistorySummary String?  @db.Text
  preferredLanguage     String   @default("en")
  consentForms          Json? // signed consent timestamps
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DoctorProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  licenseNumber      String             @unique
  licenseExpiry      DateTime?
  npiNumber          String?            @unique
  specializations    String[]
  subSpecializations String[]
  qualifications     Json[] // [{ degree, institution, year }]
  experience         Int                @default(0) // years
  bio                String?            @db.Text
  consultationFee    Float              @default(0)
  followUpFee        Float              @default(0)
  currency           String             @default("USD")
  availableFor       ConsultType[]
  languages          String[]
  rating             Float              @default(0)
  totalReviews       Int                @default(0)
  totalConsultations Int                @default(0)
  isAvailableNow     Boolean            @default(false)
  availabilitySlots  AvailabilitySlot[]
  hospital           String?
  department         String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews Review[]
}

enum ConsultType {
  VIDEO
  AUDIO
  CHAT
  IN_PERSON
}

model AvailabilitySlot {
  id           String    @id @default(cuid())
  doctorId     String
  dayOfWeek    Int // 0=Sunday, 6=Saturday
  startTime    String // "09:00"
  endTime      String // "17:00"
  slotDuration Int       @default(30) // minutes
  isRecurring  Boolean   @default(true)
  specificDate DateTime?
  isAvailable  Boolean   @default(true)
  createdAt    DateTime  @default(now())

  doctor DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// APPOINTMENTS
// ─────────────────────────────────────────────
model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  doctorId        String
  scheduledAt     DateTime
  duration        Int               @default(30)
  type            ConsultType       @default(VIDEO)
  status          AppointmentStatus @default(SCHEDULED)
  reason          String?
  symptoms        String[]
  notes           String?           @db.Text
  doctorNotes     String?           @db.Text
  diagnosis       String?           @db.Text
  followUpDate    DateTime?
  roomId          String?
  recordingUrl    String?
  cancelReason    String?
  cancelledBy     String?
  rescheduledFrom String?
  reminderSent    Boolean           @default(false)
  paymentId       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  patient       User           @relation("PatientAppointments", fields: [patientId], references: [id])
  doctor        User           @relation("DoctorAppointments", fields: [doctorId], references: [id])
  prescriptions Prescription[]
  labOrders     LabOrder[]
  videoSession  VideoSession?
  payment       Payment?       @relation(fields: [paymentId], references: [id])
  review        Review?
  messages      Message[]
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
  WAITING
}

// ─────────────────────────────────────────────
// VIDEO SESSIONS
// ─────────────────────────────────────────────
model VideoSession {
  id            String        @id @default(cuid())
  appointmentId String        @unique
  userId        String
  roomId        String        @unique
  provider      String        @default("jitsi")
  startedAt     DateTime?
  endedAt       DateTime?
  duration      Int?
  recordingUrl  String?
  transcriptUrl String?
  status        SessionStatus @default(PENDING)
  participants  Json?
  createdAt     DateTime      @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])
}

enum SessionStatus {
  PENDING
  ACTIVE
  ENDED
  FAILED
}

// ─────────────────────────────────────────────
// HEALTH RECORDS & METRICS
// ─────────────────────────────────────────────
model HealthRecord {
  id           String    @id @default(cuid())
  userId       String
  type         String
  title        String
  description  String?   @db.Text
  diagnosis    String?
  icdCode      String?
  severity     Severity?
  onsetDate    DateTime?
  resolvedDate DateTime?
  isActive     Boolean   @default(true)
  attachments  String[]
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Severity {
  MILD
  MODERATE
  SEVERE
  CRITICAL
}

model HealthMetric {
  id         String           @id @default(cuid())
  userId     String
  type       HealthMetricType
  value      Float
  value2     Float? // for BP diastolic, etc.
  unit       String
  recordedAt DateTime
  source     MetricSource     @default(MANUAL)
  deviceId   String?
  syncId     String?
  notes      String?
  isAbnormal Boolean          @default(false)
  createdAt  DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, recordedAt])
}

enum HealthMetricType {
  HEART_RATE
  BLOOD_PRESSURE_SYSTOLIC
  BLOOD_PRESSURE
  BODY_TEMPERATURE
  RESPIRATORY_RATE
  OXYGEN_SATURATION
  BLOOD_GLUCOSE
  WEIGHT
  HEIGHT
  BMI
  BODY_FAT
  STEPS
  DISTANCE
  CALORIES_BURNED
  ACTIVE_MINUTES
  EXERCISE_SESSION
  SLEEP_DURATION
  SLEEP_STAGES
  CALORIES_INTAKE
  WATER_INTAKE
  MENSTRUAL_CYCLE
  STRESS_LEVEL
  MOOD
  PAIN_LEVEL
  HYDRATION
  CERVICAL_MUCUS
  OVULATION_TEST
  BASAL_BODY_TEMP
}

enum MetricSource {
  MANUAL
  HEALTH_CONNECT
  WEARABLE
  MEDICAL_DEVICE
  IMPORTED
}

model HealthConnectSync {
  id              String     @id @default(cuid())
  userId          String
  dataType        String
  lastSyncAt      DateTime?
  syncToken       String?
  status          SyncStatus @default(PENDING)
  recordsImported Int        @default(0)
  errorMessage    String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dataType])
}

enum SyncStatus {
  PENDING
  SYNCING
  SUCCESS
  FAILED
  PARTIAL
}

model DeviceConnection {
  id           String    @id @default(cuid())
  userId       String
  deviceName   String
  deviceType   String
  manufacturer String?
  model        String?
  platform     String?
  isConnected  Boolean   @default(true)
  lastSeenAt   DateTime?
  metadata     Json?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// PRESCRIPTIONS
// ─────────────────────────────────────────────
model Prescription {
  id               String             @id @default(cuid())
  patientId        String
  doctorId         String?
  appointmentId    String?
  status           PrescriptionStatus @default(ACTIVE)
  medications      PrescriptionItem[]
  diagnosis        String?
  notes            String?            @db.Text
  issueDate        DateTime           @default(now())
  expiryDate       DateTime?
  refillsAllowed   Int                @default(0)
  refillsUsed      Int                @default(0)
  pharmacyNotes    String?
  digitalSignature String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  patient     User         @relation(fields: [patientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
}

model PrescriptionItem {
  id             String    @id @default(cuid())
  prescriptionId String
  medicationName String
  genericName    String?
  dosage         String
  form           String?
  strength       String?
  frequency      String
  route          String?
  duration       String
  quantity       Int
  refillQuantity Int       @default(0)
  instructions   String?   @db.Text
  sideEffects    String?
  interactions   String?
  isChronic      Boolean   @default(false)
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime  @default(now())

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
}

enum PrescriptionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
  ON_HOLD
}

// ─────────────────────────────────────────────
// LAB ORDERS & RESULTS
// ─────────────────────────────────────────────
model LabOrder {
  id            String         @id @default(cuid())
  patientId     String
  doctorId      String?
  appointmentId String?
  orderDate     DateTime       @default(now())
  status        LabOrderStatus @default(PENDING)
  priority      Priority       @default(ROUTINE)
  tests         LabOrderItem[]
  notes         String?
  labName       String?
  dueDate       DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  results     LabResult[]
}

model LabOrderItem {
  id         String   @id @default(cuid())
  labOrderId String
  testCode   String
  testName   String
  category   String?
  isStat     Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())

  labOrder LabOrder @relation(fields: [labOrderId], references: [id], onDelete: Cascade)
}

model LabResult {
  id             String    @id @default(cuid())
  userId         String
  labOrderId     String?
  testName       String
  testCode       String?
  value          String
  unit           String?
  referenceRange String?
  isAbnormal     Boolean   @default(false)
  abnormalFlag   String?
  interpretation String?   @db.Text
  collectedAt    DateTime?
  reportedAt     DateTime?
  labName        String?
  labTech        String?
  reviewedBy     String?
  reviewedAt     DateTime?
  attachmentUrl  String?
  createdAt      DateTime  @default(now())

  user     User      @relation(fields: [userId], references: [id])
  labOrder LabOrder? @relation(fields: [labOrderId], references: [id])
}

enum LabOrderStatus {
  PENDING
  COLLECTED
  PROCESSING
  COMPLETED
  CANCELLED
  PARTIAL
}

enum Priority {
  ROUTINE
  URGENT
  STAT
}

// ─────────────────────────────────────────────
// MESSAGING (FIXED)
// ─────────────────────────────────────────────
model Conversation {
  id        String   @id @default(cuid())
  type      ConvType @default(DIRECT)
  title     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime  @default(now())
  lastReadAt     DateTime?
  isAdmin        Boolean   @default(false)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String      @id @default(cuid())
  conversationId String?
  appointmentId  String?
  senderId       String
  content        String      @db.Text
  type           MessageType @default(TEXT)
  attachments    Json?
  isRead         Boolean     @default(false)
  readAt         DateTime?
  isDeleted      Boolean     @default(false)
  editedAt       DateTime?
  replyToId      String?
  createdAt      DateTime    @default(now())

  sender       User          @relation(fields: [senderId], references: [id])
  appointment  Appointment?  @relation(fields: [appointmentId], references: [id])
  conversation Conversation? @relation(fields: [conversationId], references: [id]) // ← FIXED
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  AUDIO
  SYSTEM
  PRESCRIPTION
  LAB_ORDER
}

enum ConvType {
  DIRECT
  GROUP
  SUPPORT
}

// ─────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────
model Payment {
  id              String         @id @default(cuid())
  userId          String
  amount          Float
  currency        String         @default("USD")
  status          PaymentStatus  @default(PENDING)
  method          PaymentMethod?
  stripePaymentId String?        @unique
  stripeSessionId String?
  description     String?
  metadata        Json?
  refundedAmount  Float?
  refundReason    String?
  paidAt          DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  appointments Appointment[]
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CARD
  BANK_TRANSFER
  INSURANCE
  WALLET
  CRYPTO
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────
model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  channel   String[]         @default(["in_app"])
  sentAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum NotificationType {
  APPOINTMENT_REMINDER
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  APPOINTMENT_STARTED
  NEW_MESSAGE
  PRESCRIPTION_READY
  LAB_RESULT_READY
  HEALTH_ALERT
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  DOCTOR_AVAILABLE
  SYSTEM
}

// ─────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────
model Review {
  id            String    @id @default(cuid())
  patientId     String
  doctorId      String
  appointmentId String    @unique
  rating        Int
  comment       String?   @db.Text
  tags          String[]
  isAnonymous   Boolean   @default(false)
  isVerified    Boolean   @default(true)
  response      String?   @db.Text
  respondedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patient     User          @relation(fields: [patientId], references: [id])
  doctor      DoctorProfile @relation(fields: [doctorId], references: [id])
  appointment Appointment   @relation(fields: [appointmentId], references: [id])
}

// ─────────────────────────────────────────────
// MEDICAL DOCUMENTS
// ─────────────────────────────────────────────
model MedicalDocument {
  id           String    @id @default(cuid())
  userId       String
  title        String
  type         DocType
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  description  String?
  tags         String[]
  isShared     Boolean   @default(false)
  sharedWith   String[]
  uploadedById String?
  date         DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum DocType {
  PRESCRIPTION
  LAB_REPORT
  IMAGING
  DISCHARGE_SUMMARY
  REFERRAL
  VACCINATION
  INSURANCE
  CONSENT
  OTHER
}

// ─────────────────────────────────────────────
// AUDIT & COMPLIANCE
// ─────────────────────────────────────────────
model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, timestamp])
  @@index([resource, resourceId])
}
